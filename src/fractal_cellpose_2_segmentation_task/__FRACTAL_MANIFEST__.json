{
  "manifest_version": "2",
  "task_list": [
    {
      "name": "Cellpose Segmentation",
      "category": "Segmentation",
      "tags": [
        "Instance Segmentation",
        "Cellpose",
        "Deep Learning"
      ],
      "docs_info": "### Purpose\n- Description and documentation of the Task functionality\n- Bullet points that cover main features of the tasks.\n- Can use **full** *markdown* formatting (including embedding images).\n\n### Outputs\n- Optional section on what kind of outputs the task generates. For the thresholding_task: Generates a new label image named `label_name`.\n\n### Limitations\n- List known limitations of the task (e.g. only works for certain data types).",
      "type": "parallel",
      "executable_parallel": "cellpose_segmentation_task.py",
      "meta_parallel": {
        "cpus_per_task": 1,
        "mem": 8000,
        "needs_gpu": true
      },
      "args_schema_parallel": {
        "$defs": {
          "CellposeCustomNormalizer": {
            "description": "Validator to handle different normalization scenarios for Cellpose models.",
            "properties": {
              "type": {
                "default": "default",
                "enum": [
                  "default",
                  "custom",
                  "no_normalization"
                ],
                "title": "Type",
                "type": "string"
              },
              "lower_percentile": {
                "anyOf": [
                  {
                    "maximum": 100,
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Lower Percentile"
              },
              "upper_percentile": {
                "anyOf": [
                  {
                    "maximum": 100,
                    "minimum": 0,
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Upper Percentile"
              },
              "lower_bound": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Lower Bound"
              },
              "upper_bound": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Upper Bound"
              }
            },
            "title": "CellposeCustomNormalizer",
            "type": "object"
          },
          "CellposeModelParams": {
            "description": "Advanced Cellpose model evaluation parameters.",
            "properties": {
              "cellprob_threshold": {
                "default": 0.0,
                "title": "Cellprob Threshold",
                "type": "number"
              },
              "flow_threshold": {
                "default": 0.4,
                "title": "Flow Threshold",
                "type": "number"
              },
              "anisotropy": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "title": "Anisotropy"
              },
              "min_size": {
                "default": 15,
                "title": "Min Size",
                "type": "integer"
              },
              "augment": {
                "default": false,
                "title": "Augment",
                "type": "boolean"
              },
              "net_avg": {
                "default": false,
                "title": "Net Avg",
                "type": "boolean"
              },
              "use_gpu": {
                "default": true,
                "title": "Use Gpu",
                "type": "boolean"
              },
              "batch_size": {
                "default": 8,
                "title": "Batch Size",
                "type": "integer"
              },
              "invert": {
                "default": false,
                "title": "Invert",
                "type": "boolean"
              },
              "tile": {
                "default": true,
                "title": "Tile",
                "type": "boolean"
              },
              "tile_overlap": {
                "default": 0.1,
                "title": "Tile Overlap",
                "type": "number"
              },
              "resample": {
                "default": true,
                "title": "Resample",
                "type": "boolean"
              },
              "interp": {
                "default": true,
                "title": "Interp",
                "type": "boolean"
              },
              "stitch_threshold": {
                "default": 0.0,
                "title": "Stitch Threshold",
                "type": "number"
              },
              "do_3D": {
                "default": true,
                "title": "Do 3D",
                "type": "boolean"
              }
            },
            "title": "CellposeModelParams",
            "type": "object"
          },
          "ChannelSelectionModel": {
            "description": "Model for channel selection.",
            "properties": {
              "mode": {
                "default": "label",
                "description": "The mode to use for channel selection. Can be \"label\", \"wavelength_id\", or \"index\".",
                "enum": [
                  "label",
                  "wavelength_id",
                  "index"
                ],
                "title": "Mode",
                "type": "string"
              },
              "identifier": {
                "description": "The identifier for the channel selection. The interpretation of this field depends\non the mode:\n- If mode is \"label\", this should be the channel label.\n- If mode is \"wavelength_id\", this should be the wavelength ID of the channel.\n- If mode is \"index\", this should be the index of the channel (must be an integer).",
                "title": "Identifier",
                "type": "string"
              }
            },
            "required": [
              "identifier"
            ],
            "title": "ChannelSelectionModel",
            "type": "object"
          },
          "CreateMaskingRoiTable": {
            "description": "Create Masking ROI Table Configuration.",
            "properties": {
              "mode": {
                "const": "Create Masking ROI Table",
                "default": "Create Masking ROI Table",
                "title": "Mode",
                "type": "string"
              },
              "table_name": {
                "default": "{label_name}_masking_ROI_table",
                "title": "Table Name",
                "type": "string"
              }
            },
            "title": "CreateMaskingRoiTable",
            "type": "object"
          },
          "GaussianBlurConfig": {
            "description": "Configuration for Gaussian blur transformation.",
            "properties": {
              "type": {
                "const": "Gaussian Blur Filter",
                "default": "Gaussian Blur Filter",
                "description": "Transformation type identifier for Gaussian blur filtering.",
                "title": "Type",
                "type": "string"
              },
              "sigma_xy": {
                "default": 2.0,
                "description": "Standard deviation for Gaussian kernel in XY plane.",
                "exclusiveMinimum": 0,
                "title": "Sigma XY",
                "type": "number"
              },
              "sigma_z": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Standard deviation for Gaussian kernel in Z axis.\nIf not specified, no blurring is applied in Z axis.",
                "title": "Sigma Z"
              }
            },
            "title": "GaussianBlurConfig",
            "type": "object"
          },
          "HistogramEqualizationConfig": {
            "description": "Configuration for Contrast Limited Adaptive Histogram Equalization (CLAHE).",
            "properties": {
              "type": {
                "const": "Histogram Equalization",
                "default": "Histogram Equalization",
                "description": "Transformation type identifier for histogram equalization.",
                "title": "Type",
                "type": "string"
              },
              "kernel_size_xy": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Shape of kernel in XY plane. If None, the default is 1/8 of image height by\n1/8 of its width.",
                "title": "Kernel Size XY"
              },
              "kernel_size_z": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Shape of kernel in Z axis. If None, the default is 1/8 of image height by\n1/8 of its width.",
                "title": "Kernel Size Z"
              },
              "clip_limit": {
                "default": 0.01,
                "description": "Clipping limit, normalized between 0 and 1 (higher values give more contrast).",
                "maximum": 1,
                "minimum": 0,
                "title": "Clip Limit",
                "type": "number"
              },
              "nbins": {
                "default": 256,
                "description": "Number of gray bins for histogram (\"data range\").",
                "title": "Nbins",
                "type": "integer"
              }
            },
            "title": "HistogramEqualizationConfig",
            "type": "object"
          },
          "IteratorConfig": {
            "description": "Advanced iterator configuration.",
            "properties": {
              "masking": {
                "default": {
                  "mode": "No Masking"
                },
                "description": "If set, the segmentation will be performed only within the confines of\nthe specified mask. A mask can be specified either by a label image or a\nMasking ROI table.",
                "discriminator": {
                  "mapping": {
                    "Masking": "#/$defs/MaskingConfig",
                    "No Masking": "#/$defs/NoMaskingConfig"
                  },
                  "propertyName": "mode"
                },
                "oneOf": [
                  {
                    "$ref": "#/$defs/NoMaskingConfig"
                  },
                  {
                    "$ref": "#/$defs/MaskingConfig"
                  }
                ],
                "title": "Masking Iterator Configuration"
              },
              "roi_table": {
                "anyOf": [
                  {
                    "type": "string"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Name of a ROI table. If set, the segmentation will be applied to each ROI\nin the table individually. This option can be combined with masking.",
                "title": "Iterate Over ROIs"
              }
            },
            "title": "IteratorConfig",
            "type": "object"
          },
          "MaskingConfig": {
            "description": "Masking configuration.",
            "properties": {
              "mode": {
                "const": "Masking",
                "default": "Masking",
                "description": "If set to \"No Masking\", the segmentation will be performed without any masking,\nwhile if set to \"Masking\", the segmentation will be performed only within the\nthe confines of the specified mask.",
                "title": "Mode",
                "type": "string"
              },
              "masking_source": {
                "default": "Table Name",
                "description": "Mode of masking to be applied.\n    - If \"Table Name\", the identifier refers to a table name. This must identify\n    a valid masking ROI table in the ome-Zarr.\n    - If \"Label Name\", the identifier refers to a label image name in the ome-Zarr.\n    In this case, the masking roi table will be built on the fly from the label\n    image.",
                "enum": [
                  "Table Name",
                  "Label Name"
                ],
                "title": "Masking Source",
                "type": "string"
              },
              "identifier": {
                "description": "Name of the masking table or label image depending on the mode.",
                "title": "Identifier",
                "type": "string"
              }
            },
            "required": [
              "identifier"
            ],
            "title": "MaskingConfig",
            "type": "object"
          },
          "MedianFilterConfig": {
            "description": "Configuration for Median filter transformation.",
            "properties": {
              "type": {
                "const": "Median Filter",
                "default": "Median Filter",
                "description": "Transformation type identifier for median filtering.",
                "title": "Type",
                "type": "string"
              },
              "size_xy": {
                "default": 2,
                "description": "Size in pixels of the median filter in XY plane.",
                "exclusiveMinimum": 0,
                "title": "Size XY",
                "type": "integer"
              },
              "size_z": {
                "anyOf": [
                  {
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "default": null,
                "description": "Size in pixels of the median filter in Z axis.\nIf not specified, no filtering is applied in Z axis.",
                "title": "Size Z"
              }
            },
            "title": "MedianFilterConfig",
            "type": "object"
          },
          "NoMaskingConfig": {
            "description": "No masking configuration.",
            "properties": {
              "mode": {
                "const": "No Masking",
                "default": "No Masking",
                "description": "If set to \"No Masking\", the segmentation will be performed without any masking,\nwhile if set to \"Masking\", the segmentation will be performed only within the\nthe confines of the specified mask.",
                "title": "Mode",
                "type": "string"
              }
            },
            "title": "NoMaskingConfig",
            "type": "object"
          },
          "SegmentationTransformConfig": {
            "description": "Configuration for pre- and post-processing steps.",
            "properties": {
              "pre_process": {
                "default": [],
                "description": "List of pre-processing steps to be applied before segmentation.",
                "items": {
                  "discriminator": {
                    "mapping": {
                      "Gaussian Blur Filter": "#/$defs/GaussianBlurConfig",
                      "Histogram Equalization": "#/$defs/HistogramEqualizationConfig",
                      "Median Filter": "#/$defs/MedianFilterConfig"
                    },
                    "propertyName": "type"
                  },
                  "oneOf": [
                    {
                      "$ref": "#/$defs/GaussianBlurConfig"
                    },
                    {
                      "$ref": "#/$defs/MedianFilterConfig"
                    },
                    {
                      "$ref": "#/$defs/HistogramEqualizationConfig"
                    }
                  ]
                },
                "title": "Pre Process",
                "type": "array"
              },
              "post_process": {
                "default": [],
                "description": "List of post-processing steps to be applied after segmentation.",
                "items": {
                  "discriminator": {
                    "mapping": {
                      "Size Filter": "#/$defs/SizeFilterConfig"
                    },
                    "propertyName": "type"
                  },
                  "oneOf": [
                    {
                      "$ref": "#/$defs/SizeFilterConfig"
                    }
                  ]
                },
                "title": "Post Process",
                "type": "array"
              }
            },
            "title": "SegmentationTransformConfig",
            "type": "object"
          },
          "SizeFilterConfig": {
            "description": "Configuration for size filter post-processing.",
            "properties": {
              "type": {
                "const": "Size Filter",
                "default": "Size Filter",
                "description": "Transformation type identifier for size filtering.",
                "title": "Type",
                "type": "string"
              },
              "min_size": {
                "description": "Minimum size in pixels for objects to keep.\nObjects smaller than this size will be removed.",
                "minimum": 0,
                "title": "Min Size",
                "type": "integer"
              }
            },
            "required": [
              "min_size"
            ],
            "title": "SizeFilterConfig",
            "type": "object"
          },
          "SkipCreateMaskingRoiTable": {
            "description": "Skip Creating Masking ROI Table Configuration.",
            "properties": {
              "mode": {
                "const": "Skip Creating Masking ROI Table",
                "default": "Skip Creating Masking ROI Table",
                "title": "Mode",
                "type": "string"
              }
            },
            "title": "SkipCreateMaskingRoiTable",
            "type": "object"
          }
        },
        "additionalProperties": false,
        "properties": {
          "zarr_url": {
            "title": "Zarr Url",
            "type": "string",
            "description": "URL to the OME-Zarr container."
          },
          "channel_1": {
            "$ref": "#/$defs/ChannelSelectionModel",
            "title": "Channel 1",
            "description": "Primary channel for segmentation (typically cytoplasm). Required."
          },
          "channel_2": {
            "anyOf": [
              {
                "$ref": "#/$defs/ChannelSelectionModel"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Channel 2",
            "description": "Optional secondary channel (typically nuclear). When provided, Cellpose is run in two-channel mode (channels=[1, 2])."
          },
          "label_name": {
            "default": "{channel_identifier}_cellpose_segmented",
            "title": "Label Name",
            "type": "string",
            "description": "Name of the resulting label image. The placeholder \"{channel_identifier}\" is replaced by the identifier of channel_1."
          },
          "level_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Level Path",
            "description": "Resolution level to use. If not provided, the highest resolution level is used."
          },
          "model_type": {
            "default": "cyto2",
            "enum": [
              "cyto",
              "nuclei",
              "tissuenet",
              "livecell",
              "cyto2",
              "general",
              "CP",
              "CPx",
              "TN1",
              "TN2",
              "TN3",
              "LC1",
              "LC2",
              "LC3",
              "LC4"
            ],
            "title": "Model Type",
            "type": "string",
            "description": "Pretrained Cellpose model name (e.g. \"cyto2\", \"nuclei\", \"cyto3\"). Ignored when custom_model_path is provided. Default: \"cyto2\"."
          },
          "custom_model_path": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Custom Model Path",
            "description": "Path to a custom Cellpose model file. When provided, takes precedence over model_type."
          },
          "diameter": {
            "default": 30.0,
            "title": "Diameter",
            "type": "number",
            "description": "Expected object diameter in pixels. Calculated in pixels => if you change the level_path (=> image resolution), also adapt the diameter accordingly."
          },
          "normalize": {
            "$ref": "#/$defs/CellposeCustomNormalizer",
            "default": {
              "type": "default",
              "lower_percentile": null,
              "upper_percentile": null,
              "lower_bound": null,
              "upper_bound": null
            },
            "title": "Normalize",
            "description": "Normalization settings for the primary channel."
          },
          "normalize_2": {
            "$ref": "#/$defs/CellposeCustomNormalizer",
            "default": {
              "type": "default",
              "lower_percentile": null,
              "upper_percentile": null,
              "lower_bound": null,
              "upper_bound": null
            },
            "title": "Normalize 2",
            "description": "Normalization settings for the secondary channel. Only used when channel_2 is provided."
          },
          "advanced_model_params": {
            "$ref": "#/$defs/CellposeModelParams",
            "default": {
              "cellprob_threshold": 0.0,
              "flow_threshold": 0.4,
              "anisotropy": null,
              "min_size": 15,
              "augment": false,
              "net_avg": false,
              "use_gpu": true,
              "batch_size": 8,
              "invert": false,
              "tile": true,
              "tile_overlap": 0.1,
              "resample": true,
              "interp": true,
              "stitch_threshold": 0.0,
              "do_3D": true
            },
            "title": "Advanced Model Params",
            "description": "Advanced Cellpose eval hyperparameters (flow_threshold, cellprob_threshold, etc.)."
          },
          "iterator_configuration": {
            "anyOf": [
              {
                "$ref": "#/$defs/IteratorConfig"
              },
              {
                "type": "null"
              }
            ],
            "default": null,
            "title": "Iterator Configuration",
            "description": "Advanced configuration to control masked and ROI-based iteration."
          },
          "pre_post_process": {
            "$ref": "#/$defs/SegmentationTransformConfig",
            "default": {
              "pre_process": [],
              "post_process": []
            },
            "title": "Pre Post Process",
            "description": "Configuration for pre- and post-processing transforms applied by the iterator."
          },
          "create_masking_roi_table": {
            "default": {
              "mode": "Skip Creating Masking ROI Table"
            },
            "discriminator": {
              "mapping": {
                "Create Masking ROI Table": "#/$defs/CreateMaskingRoiTable",
                "Skip Creating Masking ROI Table": "#/$defs/SkipCreateMaskingRoiTable"
              },
              "propertyName": "mode"
            },
            "oneOf": [
              {
                "$ref": "#/$defs/CreateMaskingRoiTable"
              },
              {
                "$ref": "#/$defs/SkipCreateMaskingRoiTable"
              }
            ],
            "title": "Create Masking Roi Table",
            "description": "Configuration to create a masking ROI table after segmentation."
          },
          "overwrite": {
            "default": true,
            "title": "Overwrite",
            "type": "boolean",
            "description": "Whether to overwrite an existing label image. Defaults to True."
          }
        },
        "required": [
          "zarr_url",
          "channel_1"
        ],
        "type": "object",
        "title": "CellposeSegmentationTask"
      },
      "docs_link": "https://github.com/fractal-analytics-platform/fractal-cellpose-2-segmentation-task"
    }
  ],
  "has_args_schemas": true,
  "args_schema_version": "fractal_schema_v1",
  "authors": "Fabio Steffen & Joel Luethi"
}
